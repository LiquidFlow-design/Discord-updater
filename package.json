{
  "name": "discord-updater",
  "version": "1.0.3",
  "description": "Discord & BetterDiscord Update Manager",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder build --win --publish never",
    "build:mac": "electron-builder build --mac --publish never",
    "build:linux": "electron-builder build --linux --publish never"
  },
  "build": {
    "appId": "com.discordupdater.app",
    "productName": "Discord Updater",
    "directories": { "output": "dist" },
    "files": ["src/**/*", "package.json"],
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "src/assets/icon.ico"
    },
    "mac": { "target": "dmg", "icon": "src/assets/icon.icns" },
    "linux": { "target": "AppImage", "icon": "src/assets/icon.png" },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Discord Updater"
    }
  },
  "dependencies": {
    "axios": "^1.7.9",
    "electron-store": "^10.0.0",
    "node-schedule": "^2.1.1"
  },
  "devDependencies": {
    "electron": "^39.8.5",
    "electron-builder": "^26.8.1"
  },
  "author": "LiquidFlow-design",
  "license": "MIT"
}
